function main(config) {
  var appleGroupName = "Apple";
  var aiGroupName = "AI_service";

  if (!Array.isArray(config["proxy-groups"])) {
    config["proxy-groups"] = [];
  }

  if (!config["rule-providers"] || typeof config["rule-providers"] !== "object") {
    config["rule-providers"] = {};
  }

  config["rule-providers"]["apple_all"] = {
    type: "http",
    behavior: "classical",
    format: "yaml",
    interval: 86400,
    url: "https://cdn.jsdmirror.com/gh/perfect-panel/rules/rule/Clash/Apple/Apple_Classical_No_Resolve.yaml"
  };

  config["rule-providers"]["ai_gemini"] = {
    type: "http",
    behavior: "classical",
    format: "yaml",
    interval: 86400,
    url: "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Gemini/Gemini.yaml"
  };

  config["rule-providers"]["ai_openai"] = {
    type: "http",
    behavior: "classical",
    format: "yaml",
    interval: 86400,
    url: "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/OpenAI/OpenAI.yaml"
  };

  config["rule-providers"]["ai_anthropic"] = {
    type: "http",
    behavior: "classical",
    format: "yaml",
    interval: 86400,
    url: "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Anthropic/Anthropic.yaml"
  };

  function ensureGroup(groupName) {
    var hasGroup = config["proxy-groups"].some(function(g) {
      return g && g.name === groupName;
    });

    if (!hasGroup) {
      config["proxy-groups"].unshift({
        name: groupName,
        type: "select",
        proxies: ["DIRECT"],
        "include-all": true
      });
    }
  }

  ensureGroup(appleGroupName);
  ensureGroup(aiGroupName);

  if (!Array.isArray(config.rules)) {
    config.rules = [];
  }

  var ruleLines = [
    "RULE-SET,ai_openai,AI_service",
    "RULE-SET,ai_gemini,AI_service",
    "RULE-SET,ai_anthropic,AI_service",
    "RULE-SET,apple_all,Apple"
  ];

  for (var i = ruleLines.length - 1; i >= 0; i--) {
    if (config.rules.indexOf(ruleLines[i]) === -1) {
      config.rules.unshift(ruleLines[i]);
    }
  }

  return config;
}
